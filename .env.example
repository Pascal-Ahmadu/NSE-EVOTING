# --- Database (Vercel Postgres / Neon) ---
# Pooled connection string used by the app at runtime.
# In Vercel: Storage > Postgres > .env.local copy this from POSTGRES_PRISMA_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct (non-pooled) connection used by `prisma migrate` only.
# In Vercel: from POSTGRES_URL_NON_POOLING.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Session encryption ---
# Used by iron-session to encrypt cookies. MUST be at least 32 chars.
# Generate one: `openssl rand -hex 32`
SESSION_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# --- Initial admin (seeded on first deploy) ---
# Used only by `prisma/seed.ts` if no admins exist yet.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_NAME="Default Admin"
SEED_ADMIN_PASSCODE="NSE1234"
